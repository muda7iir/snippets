<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_nx_project_locations" name="Project Locations">
        <section class="s_nx_project_locations o_cc o_cc1 o_colored_level pt80 pb80 position-relative" data-snippet="s_nx_project_locations" data-name="Project Locations">
            
            <!-- Background Decorative Watermarks -->
            <div class="nx-locations-bg-left d-none d-lg-block position-absolute" style="top: 10%; left: -5%; z-index: 0; pointer-events: none;">
                <img src="/nx_industry_housing/static/src/img/process-watermark.svg" class="img-fluid o_we_custom_image" alt="Decorative Shape Left"/>
            </div>
            <div class="nx-locations-bg-right d-none d-lg-block position-absolute" style="bottom: 10%; right: -5%; z-index: 0; pointer-events: none;">
                <img src="/nx_industry_housing/static/src/img/process-watermark.svg" class="img-fluid o_we_custom_image" alt="Decorative Shape Right"/>
            </div>

            <!-- Central Map Silhouette Background -->
            <div class="nx-locations-map-bg position-absolute w-100 h-100 d-flex justify-content-center align-items-center" style="top: 0; left: 0; z-index: 1; pointer-events: none;">
                <img src="/nx_industry_housing/static/src/img/map-silhouette.svg" class="img-fluid o_we_custom_image" style="max-width: 60%; opacity: var(--locations-map-opacity);" alt="Map Silhouette"/>
            </div>
            
            <!-- Bottom Ornamental Curves -->
            <div class="nx-locations-bottom-curve position-absolute w-100" style="bottom: 0; left: 0; z-index: 0; pointer-events: none;">
                <img src="/nx_industry_housing/static/src/img/ornament-curves.svg" class="img-fluid w-100 o_we_custom_image" alt="Ornamental Curve"/>
            </div>

            <div class="container position-relative" style="z-index: 2;">
                
                <!-- Heading Area -->
                <div class="row mb-5">
                    <div class="col-12 text-center nx-locations-heading-area">
                        <h2 class="nx-locations-heading fw-bold mb-3 o_default_snippet_text">PROJECT LOCATIONS</h2>
                        <div class="nx-locations-underline mx-auto"></div>
                    </div>
                </div>

                <!-- Locations Grid -->
                <div class="row justify-content-center nx-locations-grid">
                    
                    <!-- Single Showcase Card -->
                    <div class="col-lg-5 col-md-8 col-12 mb-4 nx-loc-card-wrap">
                        <div class="nx-loc-card h-100 d-flex flex-column position-relative">
                            <div class="nx-loc-pin-badge position-absolute" style="pointer-events: none;">
                                <img src="/nx_industry_housing/static/src/img/pin-active.svg" class="nx-loc-pin-img img-fluid o_we_custom_image" style="width: 65px; pointer-events: auto;" alt="Pin"/>
                            </div>
                            <div class="nx-loc-card-preview-wrap">
                                <img src="/nx_industry_housing/static/src/img/card-map-preview.svg" class="nx-loc-card-preview img-fluid o_we_custom_image" alt="Map Preview"/>
                            </div>
                            <div class="nx-loc-card-content flex-grow-1 d-flex flex-column text-center">
                                <h3 class="nx-loc-card-title mb-1 o_default_snippet_text">Project Showcase</h3>
                                <h4 class="nx-loc-card-size mb-3 o_default_snippet_text">900 Kanal</h4>
                                <div class="nx-loc-card-info-box flex-grow-1">
                                    <p class="nx-loc-card-desc-label mb-1 fw-bold o_default_snippet_text">Short Description:</p>
                                    <p class="nx-loc-card-desc o_default_snippet_text">Scenic and developing area.</p>
                                </div>
                                <div class="mt-3">
                                    <a href="#" class="btn nx-loc-btn o_default_snippet_text">View Details</a>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>
    </template>
</odoo>
