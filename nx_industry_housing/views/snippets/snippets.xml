<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ============================================================
     Register ALL NX Housing Snippets in Website Builder panel
     → Structure section (Odoo 18 pattern)
============================================================= -->

<!-- 1. President Message Card -->
<template id="nx_president_message_snippet_menu"
          inherit_id="website.snippets"
          name="President Message Card in Structure">
    <xpath expr="//snippets[@id='snippet_structure']" position="inside">
        <t t-snippet="nx_industry_housing.s_nx_president_message"
           t-thumbnail="/nx_industry_housing/static/src/img/president-message-thumb.svg"/>
    </xpath>
</template>

<!-- 2. EECHS President Message Card -->
<template id="nx_eechs_president_card_snippet_menu"
          inherit_id="website.snippets"
          name="EECHS President Card in Structure">
    <xpath expr="//snippets[@id='snippet_structure']" position="inside">
        <t t-snippet="nx_industry_housing.s_nx_eechs_president_card"
           t-thumbnail="/nx_industry_housing/static/src/img/eechs-president-thumb.svg"/>
    </xpath>
</template>

</odoo>
