<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ============================================================
     Register ALL NX Housing Snippets in Website Builder panel
     → Structure section
     Single inherited template with all snippets registered
     in one xpath block to avoid conflicts.
============================================================= -->

<template id="nx_housing_snippets_menu"
          inherit_id="website.snippets"
          name="NX Housing Snippets in Structure">
    <xpath expr="//snippets[@id='snippet_structure']" position="inside">
        <!-- 1. President Message Card -->
        <t t-snippet="nx_industry_housing.s_nx_president_message"
           string="President Message Card"
           t-thumbnail="/nx_industry_housing/static/src/img/president-message-thumb.svg"/>
        <!-- 2. EECHS President Message Card -->
        <t t-snippet="nx_industry_housing.s_nx_eechs_president_card"
           string="EECHS President Card"
           t-thumbnail="/nx_industry_housing/static/src/img/eechs-president-thumb.svg"/>
        <!-- 3. Education Department NOC Card -->
        <t t-snippet="nx_industry_housing.s_nx_noc_card"
           string="Education Department NOC Card"
           t-thumbnail="/nx_industry_housing/static/src/img/noc-card-thumb.svg"/>
        <!-- 4. Digital Process Timeline -->
        <t t-snippet="nx_industry_housing.s_nx_process_timeline"
           string="Digital Process Timeline"
           t-thumbnail="/nx_industry_housing/static/src/img/process-watermark.svg"/>
        <!-- 5. Access EECHS Anywhere -->
        <t t-snippet="nx_industry_housing.s_nx_access_anywhere"
           string="Access EECHS Anywhere"
           t-thumbnail="/nx_industry_housing/static/src/img/phone-mockup.svg"/>
    </xpath>
</template>

</odoo>
