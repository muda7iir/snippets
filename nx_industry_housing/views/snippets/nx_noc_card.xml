<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_nx_noc_card" name="Education Department NOC Card">
        <section class="s_nx_noc_card o_cc o_cc1 o_colored_level noc-theme-dark-green noc-gold-classic noc-shadow-soft noc-radius-rounded noc-watermark-subtle noc-badge-md noc-card-border-none noc-inner-medium pt80 pb80"
                 data-snippet="s_nx_noc_card"
                 data-name="Education Department NOC Card">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-10 col-md-12 col-12">

                        <div class="nx-noc-card-wrap position-relative">

                            <!-- Top Approval Badge (click to replace/resize) -->
                            <div class="noc-approval-badge position-absolute w-100 d-flex justify-content-center">
                                <img src="/nx_industry_housing/static/src/img/noc-approval-seal.svg"
                                     class="noc-approval-badge__img img-fluid o_we_custom_image"
                                     alt="Approved Badge"/>
                            </div>

                            <!-- Main White Card -->
                            <div class="nx-noc-main-card">

                                <!-- Two-Line Title -->
                                <div class="nx-noc-title-area text-center">
                                    <h2 class="nx-noc-title-l1 mb-0 o_default_snippet_text">EDUCATION DEPARTMENT</h2>
                                    <h2 class="nx-noc-title-l2 mb-0 o_default_snippet_text">NOC</h2>
                                </div>

                                <!-- Inner Green-Bordered Certificate Box -->
                                <div class="nx-noc-inner-box position-relative mt-4">

                                    <!-- Watermark -->
                                    <div class="nx-noc-watermark position-absolute d-flex align-items-center justify-content-end pe-5">
                                        <img src="/nx_industry_housing/static/src/img/default-watermark.png"
                                             class="img-fluid o_we_custom_image" alt="Watermark"/>
                                    </div>

                                    <!-- Content -->
                                    <div class="row align-items-stretch position-relative" style="z-index:1;">
                                        <!-- Left: Logo -->
                                        <div class="col-12 col-md-4 d-flex justify-content-center align-items-center mb-4 mb-md-0">
                                            <img src="/nx_industry_housing/static/src/img/default-department-logo.png"
                                                 class="nx-noc-logo img-fluid o_we_custom_image" alt="Department Logo"/>
                                        </div>
                                        <!-- Right: Details -->
                                        <div class="col-12 col-md-8 d-flex flex-column justify-content-center">
                                            <h3 class="nx-noc-cert mb-1 o_default_snippet_text">Certificate of No Objection</h3>
                                            <h4 class="nx-noc-issued mb-3 o_default_snippet_text">Issued to <strong>EECHS KP</strong></h4>
                                            <div class="nx-noc-divider mb-3"></div>
                                            <p class="nx-noc-reg mb-3 o_default_snippet_text"><strong>Regulatory Body:</strong> Khyber Pakhtunkhwa Education Department</p>

                                            <!-- NOC Number Box -->
                                            <div class="nx-noc-numbox p-3 mb-4">
                                                <h5 class="nx-noc-numbox-label mb-1 o_default_snippet_text">NOC Number:</h5>
                                                <h6 class="nx-noc-numbox-val mb-0 o_default_snippet_text">SOG/E&amp;SE/1-25/2023/COOP: Housing Society</h6>
                                            </div>

                                            <p class="nx-noc-verified mb-0 o_default_snippet_text">Verified &amp; Approved</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>
