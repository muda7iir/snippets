<odoo>
    <record id="view_nx_property_tree" model="ir.ui.view">
        <field name="name">nx.property.tree</field>
        <field name="model">nx.property</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="type_id"/>
                <field name="partner_id"/>
                <field name="status"/>
                <field name="booking_status"/>
                <field name="payment_status"/>
                <field name="price"/>
                <field name="website_published"/>
            </list>
        </field>
    </record>

    <record id="view_nx_property_form" model="ir.ui.view">
        <field name="name">nx.property.form</field>
        <field name="model">nx.property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="type_id"/>
                            <field name="partner_id"/>
                            <field name="status"/>
                            <field name="booking_status"/>
                            <field name="payment_status"/>
                        </group>
                        <group>
                            <field name="price"/>
                            <field name="currency_id"/>
                            <field name="area"/>
                            <field name="bedrooms"/>
                            <field name="bathrooms"/>
                            <field name="location"/>
                            <field name="website_published"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Images">
                            <field name="image_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="image_1920" widget="image" options="{'preview_image': 'image_1920'}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nx_property_kanban" model="ir.ui.view">
        <field name="name">nx.property.kanban</field>
        <field name="model">nx.property</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="name"/>
                <field name="type_id"/>
                <field name="status"/>
                <field name="booking_status"/>
                <field name="payment_status"/>
                <field name="price"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div><field name="type_id"/></div>
                            <div><field name="status"/></div>
                            <div><field name="booking_status"/></div>
                            <div><field name="payment_status"/></div>
                            <div><field name="price"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_nx_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">nx.property</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <record id="action_nx_property_type" model="ir.actions.act_window">
        <field name="name">Property Types</field>
        <field name="res_model">nx.property.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_nx_housing_root" name="NX Housing" sequence="10"/>
    <menuitem id="menu_nx_property" name="Properties" parent="menu_nx_housing_root" action="action_nx_property" sequence="10"/>
    <menuitem id="menu_nx_property_type" name="Property Types" parent="menu_nx_housing_root" action="action_nx_property_type" sequence="20"/>
</odoo>
