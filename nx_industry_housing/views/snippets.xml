<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_nx_property_showcase" name="NX Property Showcase">
        <section class="s_nx_property_showcase pt-5 pb-5 s_nx_property_showcase_3cols" data-layout="sm">
            <div class="container">
                <h2 class="nx-heading-h2 text-center mb-4">Featured Properties</h2>
                <div class="nx-property-grid row g-4">
                    <div class="col-sm-6 col-lg-4 nx-property-showcase__card">
                        <a href="/properties" class="nx-property-card">
                            <div class="nx-property-card__header">
                                <span class="nx-badge nx-badge-primary">Property Type</span>
                            </div>
                            <div class="nx-property-card__content">
                                <h3 class="nx-property-card__title">Property Name</h3>
                                <p class="nx-property-card__location">📍 Location</p>
                                <div class="nx-property-card__specs">
                                    <span class="nx-property-card__spec">🛏️ Bedrooms</span>
                                    <span class="nx-property-card__spec">🚿 Bathrooms</span>
                                </div>
                            </div>
                            <div class="nx-property-card__footer">
                                <span class="nx-property-card__price-value">$Price</span>
                                <span class="nx-property-card__cta">View Details →</span>
                            </div>
                        </a>
                    </div>
                    <div class="col-sm-6 col-lg-4 nx-property-showcase__card">
                        <a href="/properties" class="nx-property-card">
                            <div class="nx-property-card__header">
                                <span class="nx-badge nx-badge-primary">Property Type</span>
                            </div>
                            <div class="nx-property-card__content">
                                <h3 class="nx-property-card__title">Property Name</h3>
                                <p class="nx-property-card__location">📍 Location</p>
                                <div class="nx-property-card__specs">
                                    <span class="nx-property-card__spec">🛏️ Bedrooms</span>
                                    <span class="nx-property-card__spec">🚿 Bathrooms</span>
                                </div>
                            </div>
                            <div class="nx-property-card__footer">
                                <span class="nx-property-card__price-value">$Price</span>
                                <span class="nx-property-card__cta">View Details →</span>
                            </div>
                        </a>
                    </div>
                    <div class="col-sm-6 col-lg-4 nx-property-showcase__card">
                        <a href="/properties" class="nx-property-card">
                            <div class="nx-property-card__header">
                                <span class="nx-badge nx-badge-primary">Property Type</span>
                            </div>
                            <div class="nx-property-card__content">
                                <h3 class="nx-property-card__title">Property Name</h3>
                                <p class="nx-property-card__location">📍 Location</p>
                                <div class="nx-property-card__specs">
                                    <span class="nx-property-card__spec">🛏️ Bedrooms</span>
                                    <span class="nx-property-card__spec">🚿 Bathrooms</span>
                                </div>
                            </div>
                            <div class="nx-property-card__footer">
                                <span class="nx-property-card__price-value">$Price</span>
                                <span class="nx-property-card__cta">View Details →</span>
                            </div>
                        </a>
                    </div>
                </div>
                <div class="text-center mt-5">
                    <a href="/properties" class="btn btn-primary btn-lg nx-rounded-pill">
                        View All Properties
                    </a>
                </div>
            </div>
        </section>
    </template>

    <template id="nx_property_snippets_menu" inherit_id="website.snippets" name="NX Property Snippets">
        <xpath expr="//snippets[@id='snippet_groups']" position="inside">
            <t snippet-group="nx_properties" t-snippet="nx_industry_housing.s_nx_property_showcase" string="NX Properties" t-thumbnail="/nx_industry_housing/static/description/thumbs/s_nx_property_showcase.svg"/>
        </xpath>
        <xpath expr="//snippets[@id='snippet_structure']" position="inside">
            <t t-snippet="nx_industry_housing.s_nx_property_showcase" string="NX Property Showcase" group="nx_properties" t-thumbnail="/nx_industry_housing/static/description/thumbs/s_nx_property_showcase.svg"/>
        </xpath>
    </template>

    <template id="nx_property_snippet_options" inherit_id="website.snippet_options" name="NX Property Snippet Options">
        <xpath expr="." position="inside">
            <div data-selector=".s_nx_property_showcase" data-toggle-class="data-toggle-class" data-toggle-class-value="s_nx_property_showcase_animate">
                <we-customizeblock>
                    <we-row>
                        <we-col class="col-md-12">
                            <we-title>Properties Display</we-title>
                        </we-col>
                    </we-row>
                    <we-row>
                        <we-col class="col-md-6">
                            <we-select string="Layout" data-name="layout" data-method-name="setLayout">
                                <we-option value="3">3 Columns</we-option>
                                <we-option value="2">2 Columns</we-option>
                            </we-select>
                        </we-col>
                        <we-col class="col-md-6">
                            <we-select string="Card Style" data-name="card_style" data-method-name="setCardStyle">
                                <we-option value="full">Full Details</we-option>
                                <we-option value="minimal">Minimal</we-option>
                            </we-select>
                        </we-col>
                    </we-row>
                    <we-row>
                        <we-col class="col-md-4">
                            <we-checkbox string="Show Price" data-name="show_price" data-method-name="setShowPrice" data-true-value="true"/>
                        </we-col>
                        <we-col class="col-md-4">
                            <we-checkbox string="Show Location" data-name="show_location" data-method-name="setShowLocation" data-true-value="true"/>
                        </we-col>
                        <we-col class="col-md-4">
                            <we-checkbox string="Show Specs" data-name="show_specs" data-method-name="setShowSpecs" data-true-value="true"/>
                        </we-col>
                    </we-row>
                    <we-row>
                        <we-col class="col-md-6">
                            <we-select string="Animation" data-name="animation" data-method-name="setAnimation">
                                <we-option value="off">None</we-option>
                                <we-option value="on">Fade In</we-option>
                            </we-select>
                        </we-col>
                    </we-row>
                </we-customizeblock>
            </div>
        </xpath>
    </template>
</odoo>
