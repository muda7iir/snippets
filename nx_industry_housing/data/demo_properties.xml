<odoo>
    <!-- Property Types -->
    <record id="nx_property_type_apartment" model="nx.property.type">
        <field name="name">Apartment</field>
        <field name="sequence">10</field>
    </record>

    <record id="nx_property_type_villa" model="nx.property.type">
        <field name="name">Villa</field>
        <field name="sequence">20</field>
    </record>

    <record id="nx_property_type_townhouse" model="nx.property.type">
        <field name="name">Townhouse</field>
        <field name="sequence">30</field>
    </record>

    <record id="nx_property_type_commercial" model="nx.property.type">
        <field name="name">Commercial Space</field>
        <field name="sequence">40</field>
    </record>

    <record id="nx_property_type_plot" model="nx.property.type">
        <field name="name">Plot</field>
        <field name="sequence">50</field>
