<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="snippet_options" inherit_id="website.snippet_options" name="Process Card Options">
<xpath expr="." position="inside">

<!-- Shared options for ALL process card snippets -->
<div data-selector=".s_process_card_1, .s_process_card_2, .s_process_card_3, .s_process_card_4, .s_process_card_5, .s_process_card_6, .s_process_card_7, .s_process_card_8, .s_process_card_9, .s_process_card_10">

<we-select string="Glow Color">
<we-button data-select-class="">None</we-button>
<we-button data-select-class="s_card_glow_blue">Blue</we-button>
<we-button data-select-class="s_card_glow_teal">Teal</we-button>
<we-button data-select-class="s_card_glow_purple">Purple</we-button>
<we-button data-select-class="s_card_glow_amber">Amber</we-button>
<we-button data-select-class="s_card_glow_rose">Rose</we-button>
</we-select>

<we-select string="Shadow Intensity">
<we-button data-select-class="s_card_shadow_none">None</we-button>
<we-button data-select-class="s_card_shadow_sm">Light</we-button>
<we-button data-select-class="s_card_shadow_md" data-name="default_shadow">Medium</we-button>
<we-button data-select-class="s_card_shadow_lg">Heavy</we-button>
<we-button data-select-class="s_card_shadow_xl">Extra Heavy</we-button>
</we-select>

<we-select string="Card Radius">
<we-button data-select-class="s_card_radius_none">Sharp</we-button>
<we-button data-select-class="s_card_radius_sm">Slight</we-button>
<we-button data-select-class="s_card_radius_md" data-name="default_radius">Rounded</we-button>
<we-button data-select-class="s_card_radius_lg">Pill</we-button>
</we-select>

</div>
</xpath>
</template>
</odoo>
