<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Snippet HTML structure -->
    <template id="s_custom_hero" name="Custom Corporate Hero">
        <section class="s_custom_hero pt128 pb128 o_cc o_cc1 o_colored_level"
                 data-snippet="s_custom_hero"
                 data-name="Custom Corporate Hero"
                 style="background-image: url('/web/image/website.s_banner_default_image');
                        background-size: cover;
                        background-position: center center;
                        background-repeat: no-repeat;">
            <div class="o_we_bg_filter bg-black-50"/>
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-8 text-center">
                        <h1 class="display-3 fw-bold text-white mb-3"
                            style="text-shadow: 0 2px 8px rgba(0,0,0,0.35);">
                            The Ultimate Business OS for Your Enterprise
                        </h1>
                        <p class="lead text-white o_default_snippet_text mb-4"
                           style="opacity: 0.9;">
                            Streamline operations, automate workflows, and scale smarter
                            with our comprehensive SME Starter Packs. Seamlessly integrate
                            all your core modules into one dynamic platform.
                        </p>
                        <div class="s_btn d-inline-flex flex-wrap justify-content-center gap-2 mt-3">
                            <a href="#" class="btn btn-primary btn-lg rounded-pill px-5 py-3">
                                Get Started
                            </a>
                            <a href="#" class="btn btn-outline-light btn-lg rounded-pill px-5 py-3">
                                Explore Starter Packs
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>

    <!-- Register at the TOP of the Intro panel -->
    <template id="snippet_hero_menu"
              inherit_id="website.snippets"
              name="Custom Corporate Hero - Snippet Menu">
        <!-- Target both possible IDs to ensure it shows up in Odoo 19 -->
        <xpath expr="//snippets[@id='snippet_intro']" position="inside">
            <t t-snippet="custom_theme_hero.s_custom_hero"
               string="Custom Corporate Hero"
               t-thumbnail="/custom_theme_hero/static/src/img/s_custom_hero_thumb.svg"/>
        </xpath>
        <xpath expr="//snippets[@id='snippet_structure']" position="inside">
            <t t-snippet="custom_theme_hero.s_custom_hero"
               string="Custom Corporate Hero"
               t-thumbnail="/custom_theme_hero/static/src/img/s_custom_hero_thumb.svg"/>
        </xpath>
    </template>

</odoo>
